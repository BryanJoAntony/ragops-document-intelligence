APP_NAME=ragops-document-intelligence
APP_ENV=local
SERVICE_NAME=ragops-api

LOG_LEVEL=INFO
LOG_DIR=/app/logs

FILE_STORAGE_BACKEND=local
STORAGE_DIR=/app/storage
UPLOAD_DIR=/app/storage/uploads

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ragops_db
POSTGRES_USER=ragops_user
POSTGRES_PASSWORD=ragops_password

REDIS_HOST=redis
REDIS_PORT=6379

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=ragops_chunks

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

RETRIEVAL_TOP_K=5

ANSWER_PROVIDER=local_extractive
ANSWER_MODEL=local_extractive_v1
MAX_CONTEXT_CHUNKS=5